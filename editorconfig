# ~/.editorconfig — baseline formatting for every project under $HOME.
# Editors (nvim, VSCode, JetBrains) read this automatically. A project can
# override it with its own .editorconfig. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false   # trailing spaces are meaningful (line breaks)
