# ~/.config/ghostty/config

# Shell: use fish only inside Ghostty (the rest of the system stays on zsh)
command = /opt/homebrew/bin/fish

# Font with icons (Nerd Font) so LazyVim renders nicely
font-family = JetBrainsMono Nerd Font
font-size = 14

# Theme
theme = Kanagawa Wave

# Appearance
# Translucent background + macOS blur behind the window
background-opacity = 0.75
background-blur-radius = 60
window-padding-x = 8
window-padding-y = 8
cursor-style = block
macos-option-as-alt = true

# --- Keybindings: splits, tabs, quick terminal ---
# Splits (panes)
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+opt+left=goto_split:left
keybind = cmd+opt+right=goto_split:right
keybind = cmd+opt+up=goto_split:up
keybind = cmd+opt+down=goto_split:down
keybind = cmd+shift+enter=toggle_split_zoom
keybind = cmd+w=close_surface

# Tabs
keybind = cmd+t=new_tab
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab

# Quick terminal (global dropdown): cmd+`
quick-terminal-position = top
keybind = global:cmd+grave_accent=toggle_quick_terminal
