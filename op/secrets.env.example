# op/secrets.env — 1Password references (NOT secrets), injected at runtime.
#
# The `op://vault/item/field` paths below are just pointers; the actual secrets
# stay in 1Password. Copy this file to `op/secrets.env` and edit the paths to
# match your vault items. Then launch tools with the secrets injected — e.g. the
# `cx` fish alias runs:
#
#   op run --account my.1password.com --env-file=~/dotfiles/op/secrets.env -- claude
#
# `op run` fetches each secret (Touch ID if locked), sets it for that process
# only, and never writes it to disk. `op/secrets.env` (the real one) is gitignored.

# X (Twitter) poster — OAuth1 keys from an app with Read+Write permission.
X_API_KEY=op://Personal/X-API-poster/X_API_KEY
X_API_SECRET=op://Personal/X-API-poster/X_API_SECRET
X_BEARER_TOKEN=op://Personal/X-API-poster/BEARER_TOKEN
X_ACCESS_TOKEN=op://Personal/X-API-poster/X_ACCESS_TOKEN
X_ACCESS_TOKEN_SECRET=op://Personal/X-API-poster/X_ACCESS_TOKEN_SECRET

# Dev env secrets moved off fish_variables into 1Password.
XAI_API_KEY=op://Personal/dev-env/XAI_API_KEY
SONARQUBE_TOKEN=op://Personal/dev-env/SONARQUBE_TOKEN
