# op/secrets.env — 1Password references (NOT secrets), injected at runtime.
#
# The `op://vault/item/field` paths below are just pointers; the actual secrets
# stay in 1Password. Copy this file to `op/secrets.env` and edit the paths to
# match your vault items, then launch tools with the secrets injected:
#
#   op run --env-file=~/dotfiles/op/secrets.env -- claude
#   op run --env-file=~/dotfiles/op/secrets.env -- ccr code   # grokcode
#
# `op run` fetches each secret (Touch ID once), sets it for that process only,
# and never writes it to disk — cleaner than universal vars in fish_variables.
# `op/secrets.env` (the real one) is gitignored.

XAI_API_KEY=op://Private/xai/credential
SONARQUBE_TOKEN=op://Private/sonarqube/token
X_CLIENT_ID=op://Private/x-app/client_id
X_CLIENT_SECRET=op://Private/x-app/client_secret
