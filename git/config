# ~/.gitconfig — general config (shared). Machine-specific or secret bits go in
# ~/.gitconfig.local, pulled in by the [include] at the bottom (not tracked).

[user]
	name = Tomas Maritano
	email = tomymaritano@gmail.com

[init]
	defaultBranch = main

[pull]
	rebase = true          # rebase instead of merge on `git pull` → linear history

[push]
	autoSetupRemote = true # `git push` on a new branch just works (sets upstream)
	default = current

[fetch]
	prune = true           # drop remote-tracking branches that were deleted upstream

[core]
	editor = nvim
	excludesfile = ~/.gitignore_global
	pager = delta          # pretty diffs (needs git-delta)

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true        # n / N to jump between files in a diff
	line-numbers = true

[merge]
	conflictstyle = zdiff3 # show the common ancestor in conflicts

[rebase]
	autosquash = true
	autostash = true       # auto-stash/pop your dirty tree around a rebase

[diff]
	colorMoved = default   # highlight moved lines differently from add/remove

[color]
	ui = true

# SSH commit signing via 1Password's op-ssh-sign. Signing is only turned ON in
# ~/.gitconfig.local (with your signingkey) so commits don't fail before the
# 1Password SSH agent + key are set up. See the README for the one-time steps.
[gpg]
	format = ssh
[gpg "ssh"]
	program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[alias]
	s = status -sb
	co = checkout
	sw = switch
	br = branch
	cm = commit -m
	amend = commit --amend --no-edit
	unstage = restore --staged
	undo = reset --soft HEAD~1
	last = log -1 HEAD --stat
	lg = log --oneline --graph --decorate -20
	pushf = push --force-with-lease   # safer force-push

# Machine-local overrides / secrets (credential helpers, signing keys, the
# coderabbit machineId, work email, …). Created by install.sh if missing.
[include]
	path = ~/.gitconfig.local
