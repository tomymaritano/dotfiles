# ~/.gitignore_global — ignored in every repo (via core.excludesfile).
# Keep this to editor/OS cruft; project-specific ignores belong in the project.

# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Editor / IDE
*.swp
*.swo
*~
.idea/
.vscode/

# direnv cache (the .envrc itself is usually committed per-project)
.direnv/

# Env files with secrets
.env
.env.local
.env.*.local

# Common build / dependency dirs
node_modules/
__pycache__/
*.pyc
.venv/
